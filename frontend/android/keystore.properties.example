## Copy this file to "keystore.properties" (same directory) and fill in your
## release keystore details. keystore.properties must NOT be committed to git.
##
## Generate a keystore with:
##   keytool -genkey -v -keystore emzi-nexus-release.keystore -alias emzi-nexus -keyalg RSA -keysize 2048 -validity 10000

storeFile=../emzi-nexus-release.keystore
storePassword=CHANGE_ME
keyAlias=emzi-nexus
keyPassword=CHANGE_ME
