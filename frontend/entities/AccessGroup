{
  "name": "AccessGroup",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the access group"
    },
    "description": {
      "type": "string",
      "description": "Optional description"
    },
    "allowed_system_slugs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of public application slugs this group can access"
    },
    "user_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "User IDs assigned to this group"
    }
  },
  "required": [
    "name"
  ]
}
