{
  "name": "ApplicationReleaseNote",
  "type": "object",
  "properties": {
    "application_id": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "feature",
              "fix",
              "improvement"
            ]
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "category",
          "body"
        ]
      },
      "default": []
    },
    "is_published": {
      "type": "boolean",
      "default": true
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "is_read": {
      "type": "boolean"
    }
  },
  "required": [
    "application_id",
    "title"
  ]
}
