{
  "name": "Broadcast",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "audience_type": {
      "type": "string",
      "enum": [
        "all",
        "department",
        "individual"
      ],
      "default": "all"
    },
    "user_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "department_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "broadcast_starts_at": {
      "type": "string",
      "format": "date-time"
    },
    "broadcast_ends_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "title"
  ]
}
