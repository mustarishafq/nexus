{
  "name": "ConnectedSystem",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "description": "Unique system identifier"
    },
    "description": {
      "type": "string"
    },
    "base_url": {
      "type": "string"
    },
    "icon_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "offline",
        "maintenance",
        "degraded"
      ],
      "default": "online"
    },
    "api_key": {
      "type": "string"
    },
    "auth_mode": {
      "type": "string",
      "enum": [
        "jwt",
        "redirect"
      ],
      "default": "jwt"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ],
      "default": "public"
    },
    "created_by_user_id": {
      "type": "number"
    },
    "private_allowed_user_emails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_by_credit": {
      "type": "string"
    },
    "is_enabled": {
      "type": "boolean",
      "default": true
    },
    "last_heartbeat": {
      "type": "string",
      "format": "date-time"
    },
    "notification_config": {
      "type": "string",
      "description": "JSON config for notification channels"
    },
    "color": {
      "type": "string",
      "description": "Brand color hex"
    }
  },
  "required": [
    "name",
    "slug"
  ]
}