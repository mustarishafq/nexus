{
  "name": "ConnectedSystem",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "description": "Unique system identifier"
    },
    "description": {
      "type": "string"
    },
    "base_url": {
      "type": "string"
    },
    "icon_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "offline",
        "maintenance",
        "degraded"
      ],
      "default": "online"
    },
    "api_key": {
      "type": "string"
    },
    "is_enabled": {
      "type": "boolean",
      "default": true
    },
    "last_heartbeat": {
      "type": "string",
      "format": "date-time"
    },
    "notification_config": {
      "type": "string",
      "description": "JSON config for notification channels"
    },
    "color": {
      "type": "string",
      "description": "Brand color hex"
    }
  },
  "required": [
    "name",
    "slug"
  ]
}